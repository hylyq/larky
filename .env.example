# ==============================================================
# Larky 机器人配置
# ==============================================================

# 选择平台: feishu（飞书）/ wechat（微信）/ qq（QQ）
# 推荐使用统一接口：uv run python unified_main.py
BOT_PLATFORM=feishu

# ------------------------------------------------------------
# 飞书机器人配置（BOT_PLATFORM=feishu 时必填）
# ------------------------------------------------------------
APP_ID=cli_9fxxxx00b
APP_SECRET=EX6xxxxOF
VERIFICATION_TOKEN=cq3xxxxxxkUS
ENCRYPT_KEY=
LARK_HOST=https://open.feishu.cn
OPEN_ID=

# ------------------------------------------------------------
# QQ机器人配置（BOT_PLATFORM=qq 时必填）
# ------------------------------------------------------------
QQ_APP_ID=
QQ_APP_SECRET=

# ------------------------------------------------------------
# 微信机器人配置（BOT_PLATFORM=wechat 时无需配置，扫码登录即可使用）
# 以下为可选高级配置：
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
# WECHAT_BOT_TYPE=3
# WECHAT_LONG_POLL_TIMEOUT_MS=35000
# WECHAT_API_TIMEOUT_MS=15000
# WECHAT_CHANNEL_VERSION=2.4.6
# WECHAT_BOT_AGENT=Larky/0.1
# WECHAT_KEEPALIVE_INTERVAL_SEC=1800
# ------------------------------------------------------------

# ------------------------------------------------------------
# 通用配置
# ------------------------------------------------------------
LOG_LEVEL=INFO

# Redis 配置（多进程架构 UniedService 需要）
REDIS_URL=redis://localhost:6379
# 或
REDIS_HOST=localhost
REDIS_PORT=6379

# 消息服务 Redis 频道前缀（可选，默认 "bot"）
# 多个服务实例可使用不同前缀隔离
BOT_SERVICE_PREFIX=bot

# 备份邮件通知（所有平台通用 — 服务离线/认证过期时邮件通知）
BACKUP_EMAIL_FROM=bot@example.com
BACKUP_EMAIL_TO=your@email.com
BACKUP_EMAIL_SMTP=smtp.gmail.com
BACKUP_EMAIL_PORT=465
BACKUP_EMAIL_USER=your@gmail.com
BACKUP_EMAIL_PASSWORD=your-app-password

# 服务器标识（邮件通知中显示，可选）
SERVER_NAME=my-server

# 微信凭证存储路径（可选，默认 ~/.openclaw）
# OPENCLAW_STATE_DIR=/path/to/state
